<odoo>
    <!-- Report wizard -->
    <record id="view_attendance_report_wizard_form" model="ir.ui.view">
        <field name="name">attendance.report.wizard.form</field>
        <field name="model">attendance.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Tạo báo cáo chấm công">
                <group>
                    <field name="month" widget="selection"/>
                    <field name="year"/>
                </group>
                <footer>
                    <button string="Tạo báo cáo" type="object" name="action_generate_report" class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- ================= MENU GỐC ================= -->
    <menuitem id="menu_attendance_root"
              name="Chấm công"
              sequence="10"
              groups="base.group_user,base.group_system"/>

    <!-- ================= ACTIONS ================= -->
    <record id="action_employee_attendance_custom" model="ir.actions.act_window">
        <field name="name">Danh sách chấm công</field>
        <field name="res_model">employee.attendance.custom</field>
        <field name="view_mode">list,kanban,calendar,form</field>
    </record>

    <record id="action_employee_attendance_calendar" model="ir.actions.act_window">
        <field name="name">Lịch chấm công</field>
        <field name="res_model">employee.attendance.custom</field>
        <field name="view_mode">calendar,form</field>
        <field name="context">{'default_employee_id': uid}</field>
    </record>


    <record id="action_employee_attendance_report" model="ir.actions.act_window">
        <field name="name">Báo cáo chấm công</field>
        <field name="res_model">employee.attendance.report</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_attendance_report_wizard" model="ir.actions.act_window">
        <field name="name">Tạo báo cáo chấm công</field>
        <field name="res_model">attendance.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_attendance_report_wizard_form"/>
    </record>

    <!-- ================= MENU CHẤM CÔNG ================= -->
    <menuitem id="menu_employee_attendance_custom_list"
              name="Chấm công"
              parent="menu_attendance_root"
              action="action_employee_attendance_custom"
              sequence="15"/>

    <!-- ================= MENU TỔNG QUAN ================= -->
    <menuitem id="menu_employee_attendance_calendar"
              name="Tổng quan"
              parent="menu_attendance_root"
              action="action_employee_attendance_calendar"
              sequence="10"/>

    <!-- ================= MENU BÁO CÁO ================= -->
    <menuitem id="menu_employee_attendance_report_list"
              name="Danh sách báo cáo"
              parent="menu_attendance_root"
              action="action_employee_attendance_report"
              sequence="20"
              groups="base.group_user,hrm_overview.ut_hcm_group_manager,hrm_overview.ut_hcm_group_board"/>

    <menuitem id="menu_generate_attendance_report"
              name="Tạo báo cáo chấm công"
              parent="menu_attendance_root"
              action="action_attendance_report_wizard"
              sequence="21"
              groups="base.group_system,hrm_overview.ut_hcm_group_manager,hrm_overview.ut_hcm_group_board"/>

    <!-- ================= VIEWS ================= -->
    <!-- List view -->
    <record id="view_employee_attendance_list" model="ir.ui.view">
        <field name="name">employee.attendance.list</field>
        <field name="model">employee.attendance.custom</field>
        <field name="arch" type="xml">
            <list string="Danh sách chấm công" create="true" edit="true">
                <field name="employee_id"/>
                <field name="date"/>
                            <field name="timetable"/> <!-- hiển thị ca làm việc -->

                <field name="check_in"/>
                <field name="check_out"/>
                <field name="work_hours_display"/>
                <field name="overtime"/>
                <field name="approval_status" widget="badge"
                       options="{'accepted':'success','refused':'danger','waiting':'warning'}"/>
                <field name="status" widget="badge"
                       options="{'confirmed':'info','approved':'success','draft':'secondary'}"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_employee_attendance_form" model="ir.ui.view">
        <field name="name">employee.attendance.form</field>
        <field name="model">employee.attendance.custom</field>
        <field name="arch" type="xml">
            <form string="Chấm công nhân sự">
                <header>
                    <button name="action_open_checkin_wizard" type="object"
                            string="Check In (Wizard)" class="btn-primary"
                            invisible="status != 'draft'"/>
                    <button name="action_open_checkout_wizard" type="object"
                            string="Check Out (Wizard)" class="btn-success"
                            invisible="status != 'confirmed'"/>
                    <button name="action_submit_overtime" type="object"
                            string="Gửi duyệt OT" class="btn-warning"
                            invisible="not can_submit_overtime"/>
                    <button name="action_accept_overtime" type="object"
                            string="Chấp nhận OT" class="btn-primary" 
                            invisible="approval_status != 'waiting'"
                            groups="base.group_system,hrm_overview.ut_hcm_group_board,hrm_overview.ut_hcm_group_manager"/>
                    <button name="action_refuse_overtime" type="object"
                            string="Từ chối OT" class="btn-danger"
                            invisible="approval_status != 'waiting'"
                            groups="base.group_system,hrm_overview.ut_hcm_group_board,hrm_overview.ut_hcm_group_manager"/>
                    <field name="approval_status" widget="statusbar"
                           statusbar_visible="waiting,accepted,refused"/>
                </header>
                <sheet>
                    <notebook>
                        <page string="Chấm công">
                            <group>
                                <field name="employee_id"/>
                                <field name="timetable" readonly="1"/> <!-- HIỂN THỊ CA LÀM -->
                                <field name="date"/>
                                <field name="current_contract_id"/>
                                <field name="work_type"/>
                                <field name="check_in" readonly="1"/>
                                <field name="check_out" readonly="1"/>
                                <field name="work_hours_display" readonly="1"/>
                                <field name="overtime"/>
                                <field name="status" widget="statusbar"
                                       statusbar_visible="draft,confirmed,approved"/>
                                <field name="note"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Calendar view -->
    <record id="view_employee_attendance_calendar" model="ir.ui.view">
        <field name="name">employee.attendance.calendar</field>
        <field name="model">employee.attendance.custom</field>
        <field name="arch" type="xml">
            <calendar string="Lịch chấm công"
                      date_start="date"
                      color="display_status">
                <field name="employee_id"/>
                            <field name="timetable"/> <!-- hiển thị ca làm việc -->

                <field name="check_in"/>
                <field name="check_out"/>
            </calendar>
        </field>
    </record>

    <!-- Wizard view -->
    <record id="view_attendance_check_wizard_form" model="ir.ui.view">
        <field name="name">attendance.check.wizard.form</field>
        <field name="model">attendance.check.wizard</field>
        <field name="arch" type="xml">
            <form string="Chọn thời gian">
                <group>
                    <field name="attendance_id" invisible="1"/>
                    <field name="employee_id" readonly="1"/>
                    <field name="check_type" readonly="1"/>
                    <field name="check_datetime"/>
                    <field name="note"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Xác nhận" class="btn-primary"/>
                    <button string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Report list view -->
    <record id="view_employee_attendance_report_list" model="ir.ui.view">
        <field name="name">employee.attendance.report.list</field>
        <field name="model">employee.attendance.report</field>
        <field name="arch" type="xml">
            <list string="Báo cáo chấm công">
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="month"/>
                <field name="year"/>
                <field name="total_work_hours"/>
                <field name="total_overtime"/>
                <field name="total_leave_days"/>
                <field name="total_work_hours_with_ot" string="Tổng giờ làm + OT"/>
            </list>
        </field>
    </record>

    <!-- Report form view -->
    <record id="view_employee_attendance_report_form" model="ir.ui.view">
        <field name="name">employee.attendance.report.form</field>
        <field name="model">employee.attendance.report</field>
        <field name="arch" type="xml">
            <form string="Báo cáo chấm công">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="department_id"/>
                        <field name="month"/>
                        <field name="year"/>
                    </group>
                    <group>
                        <field name="total_work_hours"/>
                        <field name="total_overtime"/>
                        <field name="total_leave_days"/> 
                        <field name="total_work_hours_with_ot" string="Tổng giờ làm + OT"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


</odoo>
