<odoo>
    <data>
        <record id="ir_cron_contract_alert" model="ir.cron">
            <field name="name">Kiểm tra hợp đồng hết hạn</field>
            <field name="model_id" ref="hr_contract_extension.model_uth_contract"/>
            <field name="state">code</field>
            <field name="code">model.cron_check_contract_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
