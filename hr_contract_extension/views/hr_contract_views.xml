<odoo>
    <!-- =================== LỊCH LÀM VIỆC =================== -->
    <record id="action_uth_working_hours" model="ir.actions.act_window">
        <field name="name">Lịch làm việc</field>
        <field name="res_model">resource.calendar</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- =================== SEARCH VIEW =================== -->
    <record id="view_uth_contract_search" model="ir.ui.view">
        <field name="name">uth.contract.search</field>
        <field name="model">uth.contract</field>
        <field name="arch" type="xml">
            <search string="Tìm hợp đồng">
                <field name="name"/>
                <field name="employee_id"/>
                <filter name="draft" string="Nháp" domain="[('state','=','draft')]"/>
                <filter name="submitted" string="Đã gửi duyệt" domain="[('state','=','submitted')]"/>
                <filter name="running" string="Đang chạy" domain="[('state','=','running')]"/>
                <filter name="rejected" string="Từ chối" domain="[('state','=','rejected')]"/>
                <filter name="expired" string="Hết hạn" domain="[('state','=','expired')]"/>
                <filter name="contract_type_id" string="Loại hợp đồng" domain="[]"/>
            </search>
        </field>
    </record>

    <!-- =================== FORM VIEW =================== -->
    <record id="view_uth_contract_form" model="ir.ui.view">
        <field name="name">uth.contract.form</field>
        <field name="model">uth.contract</field>
        <field name="arch" type="xml">
            <form string="Hợp đồng nhân sự">
                <header>
                    <field name="state" widget="statusbar"
                        options="{'draft':'secondary','submitted':'info','running':'primary','rejected':'danger','expired':'warning'}"/>
                    <button name="action_submit" type="object" string="Gửi duyệt" class="btn-primary"
                        invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Duyệt" class="btn-success"
                        invisible="state != 'submitted'"/>
                    <button name="action_reject" type="object" string="Từ chối" class="btn-danger"
                        invisible="state != 'submitted'"/>
                    <button name="action_renew" type="object" string="Gia hạn" class="btn-warning"
                        invisible="state != 'expired'"/>
                    <button name="unlink" type="object" string="Xóa" class="oe_link" invisible="state != 'draft'"/>
                    <button name="action_update_state" type="object" string="Cập nhật trạng thái"
                        class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="employee_name" readonly="1"/>
                            <field name="contract_type_id"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="position" readonly="1"/>
                            <field name="department" readonly="1"/>
                            <field name="state" readonly="1"/>
                            <field name="calendar_id"/>
                        </group>
                    </group>

                    <group string="Lương &amp; Phụ cấp">
    <!-- Lương cơ bản: ẩn khi là HĐ khoán -->
    <field name="basic_salary" invisible="is_khoan"/>

    <!-- Lương khoán: chỉ hiện khi là HĐ khoán -->
    <field name="contract_salary" invisible="not is_khoan"/>

    <field name="total_allowance" readonly="1"/>
</group>


                    <notebook>
                        <page string="Chi tiết phụ cấp">
                            <group col="2">
                                <!-- Cột trái -->
                                <group>
                                    <field name="allowance_line_ids" nolabel="1">
                                        <list editable="bottom">
                                            <field name="name"/>
                                            <field name="amount"/>
                                        </list>
                                    </field>
                                </group>

                                <!-- Cột phải (tạm trống, có thể thêm ghi chú hoặc info khác) -->
                                <group>
                                    <field name="notes"/>
                                </group>
                            </group>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- =================== LIST VIEW =================== -->
    <record id="view_uth_contract_list" model="ir.ui.view">
        <field name="name">uth.contract.list</field>
        <field name="model">uth.contract</field>
        <field name="arch" type="xml">
            <list string="Danh sách hợp đồng">
                <field name="name"/>
                <field name="employee_name"/>
                <field name="contract_type_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="position"/>
                <field name="department"/>
                <field name="state"/>
                <field name="basic_salary"/>
                <field name="contract_salary"/>
                <field name="total_allowance"/>
                <header>
                    <button name="action_update_state" string="Cập nhật trạng thái" type="object"
                        class="btn-secondary" icon="fa-refresh"/>
                </header>
            </list>
        </field>
    </record>

    <!-- =================== DANH MỤC LOẠI HỢP ĐỒNG =================== -->
    <record id="view_uth_contract_type_list" model="ir.ui.view">
        <field name="name">uth.contract.type.list</field>
        <field name="model">uth.contract.type</field>
        <field name="arch" type="xml">
            <list string="Danh sách loại hợp đồng">
                <field name="name"/>
                <field name="code"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_uth_contract_type_form" model="ir.ui.view">
        <field name="name">uth.contract.type.form</field>
        <field name="model">uth.contract.type</field>
        <field name="arch" type="xml">
            <form string="Loại hợp đồng">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_uth_contract_type" model="ir.actions.act_window">
        <field name="name">Loại hợp đồng</field>
        <field name="res_model">uth.contract.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- =================== ACTION HỢP ĐỒNG =================== -->
    <record id="action_uth_contract" model="ir.actions.act_window">
        <field name="name">Hợp đồng</field>
        <field name="res_model">uth.contract</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_uth_contract_search"/>
    </record>

    <!-- =================== MENU =================== -->
    <menuitem id="menu_uth_contract_root" name="Hợp đồng" sequence="10"/>
    <menuitem id="menu_uth_contract" name="Hợp đồng" parent="menu_uth_contract_root" sequence="1"
        action="action_uth_contract"/>
    <menuitem id="menu_uth_contract_type" name="Loại hợp đồng" parent="menu_uth_contract_root" sequence="2"
        action="action_uth_contract_type"/>
    <menuitem id="menu_uth_working_hours" name="Quản lý lịch làm việc" parent="menu_uth_contract_root" sequence="3"
        action="action_uth_working_hours"/>


</odoo>
