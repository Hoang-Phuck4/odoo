<odoo>
    <data noupdate="0">

        <!-- Kanban view cho Học hàm / Học vị -->
        <record id="view_degree_kanban" model="ir.ui.view">
            <field name="name">degree.kanban</field>
            <field name="model">degree</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_example">
                    <field name="name"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <strong t-if="record.name.value"><field name="name"/></strong>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Form view cho Học hàm / Học vị -->
        <record id="view_degree_form" model="ir.ui.view">
            <field name="name">degree.form</field>
            <field name="model">degree</field>
            <field name="arch" type="xml">
                <form string="Học hàm / Học vị">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action window cho Học hàm / Học vị -->
        <record id="action_degree" model="ir.actions.act_window">
            <field name="name">Học hàm / Học vị</field>
            <field name="res_model">degree</field>
            <field name="view_mode">kanban,form</field>
            <field name="view_id" ref="view_degree_kanban"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Tạo học hàm / học vị mới</p>
            </field>
        </record>

        <!-- Menu Học hàm / Học vị -->
        <record id="uth_hr_menu_degree" model="ir.ui.menu">
            <field name="name">Học hàm / Học vị</field>
            <field name="parent_id" ref="hr.menu_hr_root"/>
            <field name="action" ref="action_degree"/>
            <field name="sequence">17</field>
        </record>

    </data>
</odoo>
