<odoo>
    <data noupdate="0">

        <!-- Kanban view cho Loại nhân viên -->
        <record id="view_employee_type_kanban" model="ir.ui.view">
            <field name="name">employee.type.kanban</field>
            <field name="model">employee.type</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_example">
                    <field name="name"/>
                    <field name="code"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <strong><field name="name"/></strong>
                                <div>Mã: <field name="code"/></div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Form view cho Loại nhân viên -->
        <record id="view_employee_type_form" model="ir.ui.view">
            <field name="name">employee.type.form</field>
            <field name="model">employee.type</field>
            <field name="arch" type="xml">
                <form string="Loại nhân viên">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action window cho Loại nhân viên -->
        <record id="action_employee_type" model="ir.actions.act_window">
            <field name="name">Loại nhân viên</field>
            <field name="res_model">employee.type</field>
            <field name="view_mode">kanban,form</field>
            <field name="view_id" ref="view_employee_type_kanban"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Tạo loại nhân viên mới</p>
            </field>
        </record>

        <!-- Menu Loại nhân viên -->
        <record id="uth_hr_menu_employee_type" model="ir.ui.menu">
            <field name="name">Loại nhân viên</field>
            <field name="parent_id" ref="hr.menu_hr_root"/>
            <field name="action" ref="action_employee_type"/>
            <field name="sequence">15</field>
        </record>

    </data>
</odoo>
